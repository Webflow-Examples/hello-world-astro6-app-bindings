---
const BINDINGS = [
  {
    key: 'd1',
    name: 'D1',
    title: 'SQL database',
    description: 'Serverless SQLite at the edge. Great for user data, CMS content, app state.',
    docs: 'https://developers.webflow.com/webflow-cloud/storing-data/sqlite',
  },
  {
    key: 'r2',
    name: 'R2',
    title: 'Object storage',
    description: 'S3-compatible object storage with zero egress fees. Ideal for uploads and assets.',
    docs: 'https://developers.webflow.com/webflow-cloud/storing-data/object-storage',
  },
  {
    key: 'kv_sessions',
    name: 'KV · Sessions',
    title: 'Session store',
    description: 'Low-latency key-value store. Perfect for sessions, caches, and tokens.',
    docs: 'https://developers.webflow.com/webflow-cloud/storing-data/key-value-store',
  },
  {
    key: 'kv_flags',
    name: 'KV · Flags',
    title: 'Feature flags',
    description: 'KV namespace dedicated to feature flags with instant global propagation.',
    docs: 'https://developers.webflow.com/webflow-cloud/storing-data/key-value-store',
  },
];
---

<div class="wf-section-title">
  <h2>Cloudflare bindings</h2>
  <p data-bindings-status>Checking…</p>
</div>

<div class="wf-bindings">
  {BINDINGS.map((b) => (
    <div class="wf-binding" data-binding={b.key} data-status="loading">
      <div class="wf-binding-head">
        <span class="wf-binding-name">{b.name}</span>
        <span class="wf-dot" data-dot></span>
      </div>
      <h3 class="wf-binding-title">{b.title}</h3>
      <p class="wf-binding-desc">{b.description}</p>
      <div class="wf-binding-meta">
        <span data-latency>…</span>
        <a href={b.docs} target="_blank" rel="noreferrer">Docs ↗</a>
      </div>
    </div>
  ))}
</div>

<script>
  (async () => {
    const statusEl = document.querySelector('[data-bindings-status]');
    const cards = document.querySelectorAll<HTMLElement>('[data-binding]');
    try {
      // import.meta.env.BASE_URL is populated by Astro from the `base` config
      // (set in astro.config.mjs from COSMIC_MOUNT_PATH). It always has a
      // trailing slash, so `${BASE_URL}api/...` works whether base is "/" or
      // "/mount-path/". Plain "api/..." would fail when the page URL lacks
      // a trailing slash.
      const res = await fetch(`${import.meta.env.BASE_URL}api/binding-status`, { cache: 'no-store' });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();
      if (statusEl) statusEl.textContent = `Last checked ${new Date(data.timestamp).toLocaleTimeString()}`;
      cards.forEach((card) => {
        const key = card.dataset.binding as keyof typeof data.services;
        const svc = data.services?.[key];
        card.dataset.status = svc?.status ?? 'error';
        const dot = card.querySelector<HTMLElement>('[data-dot]');
        const lat = card.querySelector<HTMLElement>('[data-latency]');
        if (dot) dot.dataset.status = svc?.status ?? 'error';
        if (lat) lat.textContent = svc ? `${svc.latency}ms` : '—';
      });
    } catch (e) {
      if (statusEl) statusEl.textContent = `Unreachable · ${e instanceof Error ? e.message : 'error'}`;
      cards.forEach((card) => {
        card.dataset.status = 'error';
        const dot = card.querySelector<HTMLElement>('[data-dot]');
        if (dot) dot.dataset.status = 'error';
      });
    }
  })();
</script>
